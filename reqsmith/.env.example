# Core
DATABASE_URL=postgresql+asyncpg://reqsmith:reqsmith@localhost:5432/reqsmith
DEBUG=false
SERVER_PORT=8000

# Version triple (recorded on every artifact + audit event)
PROMPT_PACK_VERSION=v1
POLICY_PACK_VERSION=v1

# LLM (Anthropic)
ANTHROPIC_API_KEY=
MODEL_DRAFTING=claude-sonnet-4-6
MODEL_JUDGE=claude-haiku-4-5-20251001
MAX_TOKENS_PER_RUN=200000

# Jira Cloud (REST: webhooks re-fetch, fields, transitions, publishes)
JIRA_BASE_URL=https://yourtenant.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_WEBHOOK_SECRET=
JIRA_PROJECT_KEY=
JIRA_FIELD_RISK_TIER=customfield_10001
JIRA_FIELD_CONFIDENCE=customfield_10002
JIRA_FIELD_PROVENANCE=customfield_10003
JIRA_FIELD_RUN_STATE=customfield_10004

# Atlassian Remote MCP (agent-facing reads)
ATLASSIAN_MCP_URL=https://mcp.atlassian.com/v1/sse
ATLASSIAN_MCP_CLIENT_ID=
ATLASSIAN_MCP_CLIENT_SECRET=
ATLASSIAN_MCP_REFRESH_TOKEN=

# Teams bot (M7)
BOT_APP_ID=
BOT_APP_PASSWORD=
TEAMS_TENANT_ID=

# Microsoft Graph daemon app (M8)
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
HUMAN_OWNER_AAD_ID=

# Outreach
OUTREACH_PAUSED=false
